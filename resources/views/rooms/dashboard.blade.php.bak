<script>
    function refreshRooms() {
        var statusFilter = document.querySelector('select[name="status_filter"]') ? document.querySelector('select[name="status_filter"]').value : 'all';
        var roomType = document.querySelector('select[name="room_type"]') ? document.querySelector('select[name="room_type"]').value : 'all';
        var dateFrom = document.querySelector('input[name="date_from"]') ? document.querySelector('input[name="date_from"]').value : '';
        var dateTo = document.querySelector('input[name="date_to"]') ? document.querySelector('input[name="date_to"]').value : '';

        var params = new URLSearchParams({ status_filter: statusFilter, room_type: roomType, date_from: dateFrom, date_to: dateTo });
        fetch('{{ route("rooms.api") }}?' + params.toString())
            .then(function(res) { return res.json(); })
            .then(function(data) {
                document.getElementById('availableCount').innerText = data.available_count;
                document.getElementById('checkinsCount').innerText = data.checkins_today;
                document.getElementById('checkoutsCount').innerText = data.checkouts_today;
                
                var grid = document.getElementById('roomsGrid');
                grid.innerHTML = '';
                data.rooms.forEach(function(room) {
                    var isDueOut = data.due_out_room_ids.indexOf(room.id) !== -1;
                    var statusClass = '', icon = '', statusLabel = '';
                    if (room.status === 'available') {
                        statusClass = 'bg-green-100 border-green-500 text-green-800';
                        icon = 'fa-check-circle';
                        statusLabel = 'Available';
                    } else if (room.status === 'occupied') {
                        if (isDueOut) {
                            statusClass = 'bg-orange-100 border-orange-500 text-orange-800';
                            icon = 'fa-clock';
                            statusLabel = 'Due Out';
                        } else {
                            statusClass = 'bg-red-100 border-red-500 text-red-800';
                            icon = 'fa-ban';
                            statusLabel = 'Occupied';
                        }
                    } else if (room.status === 'maintenance') {
                        statusClass = 'bg-gray-100 border-gray-500 text-gray-800';
                        icon = 'fa-tools';
                        statusLabel = 'Maintenance';
                    } else {
                        statusClass = 'bg-yellow-100 border-yellow-500 text-yellow-800';
                        icon = 'fa-broom';
                        statusLabel = room.status.charAt(0).toUpperCase() + room.status.slice(1);
                    }

                    var guestName = '';
                    if (room.reservations && room.reservations.length > 0 && room.reservations[0].guest) {
                        guestName = room.reservations[0].guest.guest_name;
                    }

                    var card = document.createElement('div');
                    card.className = 'border rounded-lg p-3 text-center cursor-pointer hover:shadow-md transition';
                    card.onclick = function() { window.location.href = '/booking/create?room_id=' + room.id; };

                    var guestHtml = guestName ? '<p class="text-xs mt-1 truncate text-blue-700 font-medium" title="' + guestName + '"><i class="fas fa-user mr-1"></i>' + guestName + '</p>' : '';

                    card.innerHTML = '<div class="rounded-lg p-2 ' + statusClass + '">' +
                        '<i class="fas ' + icon + ' text-lg"></i>' +
                        '<p class="font-bold text-lg">' + room.room_number + '</p>' +
                        '<p class="text-xs">' + (room.room_type_name || 'Standard') + '</p>' +
                        '<p class="text-xs mt-1 font-semibold">' + statusLabel + '</p>' +
                        guestHtml +
                        '</div>';
                    grid.appendChild(card);
                });
            });
    }
    
    setInterval(refreshRooms, 30000);
</script>
@endsection
